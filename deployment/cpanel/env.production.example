APP_NAME="DPF"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://laznasdpf.org
FRONTEND_URL=https://laznasdpf.org
SANCTUM_STATEFUL_DOMAINS=laznasdpf.org,www.laznasdpf.org

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.laznasdpf.org

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@laznasdpf.org
MAIL_FROM_NAME="${APP_NAME}"

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SKIP_SIGNATURE=false

ALADHAN_BASE_URL=https://api.aladhan.com/v1

BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api/v1"
VITE_BACKEND_URL="${APP_URL}"
VITE_STORAGE_URL="${APP_URL}/storage"
VITE_MIDTRANS_CLIENT_KEY="${MIDTRANS_CLIENT_KEY}"
VITE_MIDTRANS_SNAP_URL=https://app.midtrans.com/snap/snap.js
VITE_MIDTRANS_IS_PRODUCTION=true
VITE_GOOGLE_CLIENT_ID=
